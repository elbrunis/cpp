NAME        = violence
CC          = c++
FLAGS       = -Wall -Wextra -Werror -std=c++98

# Lista de archivos fuente
SRC         = main.cpp \
              Weapon.cpp \
              HumanA.cpp \
              HumanB.cpp

OBJ         = $(SRC:.cpp=.o)

all: $(NAME)

$(NAME): $(OBJ)
	$(CC) $(FLAGS) $(OBJ) -o $(NAME)

%.o: %.cpp
	$(CC) $(FLAGS) -c $< -o $@

clean:
	rm -f $(OBJ)

fclean: clean
	rm -f $(NAME)

re: fclean all

.PHONY: all clean fclean re